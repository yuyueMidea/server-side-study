{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "P2P Transfer",
  "version": "0.1.0",
  "identifier": "com.p2p-transfer.app",
  "build": {
    "beforeDevCommand":   "npm run dev",
    "devUrl":             "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist":       "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label":      "main",
        "title":      "P2P Transfer",
        "width":      580,
        "height":     720,
        "minWidth":   440,
        "minHeight":  560,
        "resizable":  true,
        "center":     true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell":  {}
  }
}
